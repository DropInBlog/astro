---
import config from 'virtual:dropinblog/config';
import Layout from 'virtual:dropinblog/layout';
import DibBlogHead from '@dropinblog/astro/components/DibBlogHead.astro';
import DibBlogBody from 'virtual:dropinblog/body';
import { isNotFound, loadPost } from '@dropinblog/astro/runtime';

export * from 'virtual:dropinblog/paths/post';

const slug = String(Astro.params.slug);
const { cacheKey, noindex } = Astro.props as { cacheKey?: string; noindex?: boolean };

let data;
try {
  data = await loadPost(config, slug, cacheKey);
} catch (error) {
  if (isNotFound(error)) {
    return new Response(null, { status: 404 });
  }
  throw error;
}

const head_data = noindex ? { ...data.head_data, noindex: true } : data.head_data;
---
<Layout title={data.head_data?.title}>
  <DibBlogHead slot="head" head_data={head_data} ogType="article" />
  <DibBlogBody kind="post" slug={slug} body_html={data.body_html} />
</Layout>
