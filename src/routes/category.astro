---
import config from 'virtual:dropinblog/config';
import Layout from 'virtual:dropinblog/layout';
import DibBlogHead from '@dropinblog/astro/components/DibBlogHead.astro';
import DibBlogBody from 'virtual:dropinblog/body';
import { isNotFound, loadCategory } from '@dropinblog/astro/runtime';

export * from 'virtual:dropinblog/paths/category';

const slug = String(Astro.params.slug);
const cacheKey = (Astro.props as { cacheKey?: string }).cacheKey;

let data;
try {
  data = await loadCategory(config, slug, 1, cacheKey);
} catch (error) {
  if (isNotFound(error)) {
    return new Response(null, { status: 404 });
  }
  throw error;
}
---
<Layout title={data.head_data?.title}>
  <DibBlogHead slot="head" head_data={data.head_data} />
  <DibBlogBody kind="category" slug={slug} page={1} body_html={data.body_html} />
</Layout>
